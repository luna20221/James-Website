<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>JW Carpet Care Instant Quote</title>
  <meta name="description" content="JW Carpet Care instant quote calculator for carpets, rugs, upholstery and commercial work." />
  <style>
    :root{
      --bg:#eef4fb;
      --ink:#122033;
      --muted:#60718a;
      --brand:#1f5fbf;
      --brand2:#163f7d;
      --brand3:#0d2548;
      --green:#14945c;
      --green2:#0f7447;
      --red:#cf3f3f;
      --card:#ffffff;
      --line:rgba(12,24,40,.10);
      --shadow:0 18px 48px rgba(13,27,45,.10);
      --shadow-soft:0 10px 24px rgba(15,35,65,.07);
      --r:22px;
      --max:1280px;
      --font:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial;
    }

    *{box-sizing:border-box}
    html,body{margin:0;padding:0}
    body{
      font-family:var(--font);
      color:var(--ink);
      background:
        radial-gradient(900px 440px at 10% 0%, rgba(31,95,191,.12), transparent 60%),
        radial-gradient(700px 340px at 100% 10%, rgba(20,148,92,.08), transparent 55%),
        linear-gradient(180deg, #0d1f39 0%, #15335e 300px, var(--bg) 301px);
      padding-bottom:92px;
    }

    a{text-decoration:none;color:inherit}
    .hidden{display:none !important}

    .wrap{
      max-width:var(--max);
      margin:0 auto;
      padding:18px 14px 28px;
    }

    .topbar{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:14px;
      flex-wrap:wrap;
      color:#fff;
      padding:6px 0 14px;
    }

    .brand{
      display:flex;
      align-items:center;
      gap:12px;
      min-width:0;
    }

    .brand img{
      height:48px;
      width:auto;
      border-radius:10px;
      background:rgba(255,255,255,.10);
      padding:4px;
      box-shadow:0 10px 22px rgba(0,0,0,.18);
    }

    .brand-copy{min-width:0}

    .brand-title{
      font-size:13px;
      font-weight:900;
      letter-spacing:.12em;
      text-transform:uppercase;
      opacity:.92;
    }

    .brand span{
      display:block;
      font-size:13px;
      opacity:.84;
      margin-top:4px;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
      max-width:420px;
    }

    .top-actions{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
    }

    .btn{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:8px;
      border:0;
      cursor:pointer;
      padding:11px 15px;
      border-radius:999px;
      font-weight:900;
      font-size:13px;
      white-space:nowrap;
      box-shadow:0 12px 28px rgba(0,0,0,.16);
      transition:transform .12s ease, box-shadow .12s ease, filter .12s ease;
    }
    .btn:hover{transform:translateY(-1px);filter:saturate(1.03)}
    .btn.primary{background:linear-gradient(135deg,var(--brand),var(--brand2));color:#fff}
    .btn.ghost{background:rgba(255,255,255,.12);color:#fff;border:1px solid rgba(255,255,255,.16)}
    .btn.green{background:linear-gradient(135deg,var(--green),var(--green2));color:#fff}
    .btn.red{background:linear-gradient(135deg,#ef5350,#c62828);color:#fff}
    .btn.small{padding:10px 12px;font-size:12px;box-shadow:none}

    .hero{
      position:relative;
      overflow:hidden;
      background:linear-gradient(135deg,#10305d 0%, #0d2548 56%, #09182d 100%);
      color:#fff;
      border-radius:24px;
      padding:18px 18px 16px;
      box-shadow:0 24px 60px rgba(0,0,0,.18);
    }

    .hero::after{
      content:"";
      position:absolute;
      inset:auto -80px -100px auto;
      width:280px;
      height:280px;
      background:radial-gradient(circle, rgba(255,255,255,.14), transparent 68%);
      pointer-events:none;
    }

    .hero-top{
      position:relative;
      z-index:1;
      display:flex;
      align-items:flex-end;
      justify-content:space-between;
      gap:14px;
      flex-wrap:wrap;
    }

    .hero-copy{max-width:720px}

    .hero-kicker{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:6px 10px;
      border-radius:999px;
      background:rgba(255,255,255,.10);
      border:1px solid rgba(255,255,255,.12);
      font-size:11px;
      font-weight:900;
      letter-spacing:.08em;
      text-transform:uppercase;
      margin-bottom:10px;
    }

    .hero h1{
      margin:0;
      font-size:28px;
      line-height:1.04;
      letter-spacing:-.03em;
    }

    .hero p{
      margin:8px 0 0;
      color:rgba(255,255,255,.86);
      font-size:13.5px;
      line-height:1.55;
      max-width:62ch;
    }

    .hero-total{
      display:flex;
      align-items:center;
      gap:10px;
      padding:10px 12px;
      border-radius:16px;
      background:rgba(255,255,255,.10);
      border:1px solid rgba(255,255,255,.12);
      backdrop-filter:blur(10px);
    }

    .hero-total b{display:block;font-size:18px}
    .hero-total span{display:block;font-size:12px;opacity:.84}

    .hero-showcase{
      position:relative;
      z-index:1;
      margin-top:14px;
      border-radius:18px;
      overflow:hidden;
      border:1px solid rgba(255,255,255,.14);
      box-shadow:0 16px 34px rgba(0,0,0,.18);
    }

    .hero-showcase img{
      display:block;
      width:100%;
      height:220px;
      object-fit:cover;
      object-position:center 40%;
    }

    .grid{
      display:grid;
      grid-template-columns:1.1fr .9fr;
      gap:18px;
      align-items:start;
      margin-top:18px;
    }

    .card{
      background:rgba(255,255,255,.94);
      backdrop-filter:blur(10px);
      border:1px solid rgba(255,255,255,.55);
      border-radius:var(--r);
      box-shadow:var(--shadow);
      overflow:hidden;
    }

    .card-h{
      padding:16px 16px 14px;
      border-bottom:1px solid rgba(12,24,40,.08);
      background:linear-gradient(135deg, rgba(31,95,191,.08), rgba(20,148,92,.05));
    }

    .card-h h2{
      margin:0;
      font-size:18px;
      letter-spacing:-.02em;
    }

    .card-h small{
      display:block;
      margin-top:5px;
      color:var(--muted);
      font-weight:800;
    }

    .card-b{padding:16px}

    .summary{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:12px;
      margin-bottom:14px;
    }

    .total-box,.info-box{
      background:linear-gradient(135deg,#fff,#f7fbff);
      border:1px solid rgba(12,24,40,.08);
      border-radius:18px;
      padding:14px;
      box-shadow:var(--shadow-soft);
    }

    .total-box{
      background:
        radial-gradient(340px 120px at 0% 0%, rgba(31,95,191,.10), transparent 55%),
        linear-gradient(135deg,#fff,#f7fbff);
    }

    .total-box b{
      display:block;
      font-size:32px;
      letter-spacing:-.04em;
      margin-top:6px;
      color:var(--brand3);
    }

    .total-box span,.info-box span{
      font-size:12px;
      color:var(--muted);
      font-weight:900;
      text-transform:uppercase;
      letter-spacing:.04em;
    }

    .note{
      font-size:12.5px;
      line-height:1.55;
      color:var(--muted);
      font-weight:700;
      margin:0;
    }

    .section-head{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      margin-top:16px;
      padding-top:14px;
      border-top:1px dashed rgba(12,24,40,.12);
      font-weight:950;
    }

    .plus{
      width:30px;
      height:30px;
      border-radius:12px;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      color:#fff;
      background:linear-gradient(135deg,var(--brand),var(--brand2));
      margin-right:8px;
      box-shadow:0 10px 22px rgba(31,95,191,.25);
    }

    .items{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(240px,1fr));
      gap:12px;
      margin-top:12px;
    }

    .item{
      position:relative;
      background:
        radial-gradient(260px 120px at 0% 0%, rgba(31,95,191,.11), transparent 60%),
        linear-gradient(135deg,#ffffff,#f8fbff);
      border:1px solid rgba(31,95,191,.14);
      border-radius:18px;
      padding:13px;
      display:flex;
      justify-content:space-between;
      gap:12px;
      align-items:flex-start;
      box-shadow:0 12px 24px rgba(15,35,65,.08), 0 0 0 1px rgba(255,255,255,.70) inset;
      transition:transform .12s ease, box-shadow .12s ease, border-color .12s ease;
    }

    .item:hover{
      transform:translateY(-2px);
      border-color:rgba(31,95,191,.24);
      box-shadow:0 16px 30px rgba(15,35,65,.12), 0 0 0 1px rgba(255,255,255,.85) inset;
    }

    .item h3{margin:0;font-size:14px;line-height:1.2}
    .item p{margin:6px 0 0;font-size:12px;color:var(--muted);font-weight:800}
    .price{margin-top:8px;color:var(--green);font-size:14px;font-weight:950}

    .qty{
      display:flex;
      align-items:center;
      gap:8px;
    }

    .qbtn{
      width:36px;
      height:36px;
      border-radius:12px;
      border:1px solid rgba(12,24,40,.08);
      background:#fff;
      box-shadow:0 10px 18px rgba(10,18,32,.08);
      font-weight:950;
      cursor:pointer;
      transition:transform .12s ease, box-shadow .12s ease;
    }

    .qbtn:hover{
      transform:translateY(-1px);
      box-shadow:0 12px 20px rgba(10,18,32,.10);
    }

    .qnum{
      width:34px;
      text-align:center;
      font-weight:950;
      font-size:15px;
    }

    details.acc{
      margin-top:12px;
      border:1px solid rgba(12,24,40,.08);
      border-radius:18px;
      overflow:hidden;
      background:#fff;
      box-shadow:var(--shadow-soft);
    }

    details.acc>summary{
      list-style:none;
      cursor:pointer;
      padding:13px 14px;
      font-weight:950;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      background:linear-gradient(135deg, rgba(31,95,191,.06), rgba(20,148,92,.04));
    }

    details.acc>summary::-webkit-details-marker{display:none}
    .acc-body{padding:12px 14px 14px;border-top:1px solid rgba(12,24,40,.08)}

    .list{
      display:flex;
      flex-direction:column;
      gap:10px;
    }

    .line{
      display:flex;
      justify-content:space-between;
      gap:10px;
      align-items:flex-start;
      padding:12px 12px;
      border:1px solid rgba(12,24,40,.08);
      border-radius:16px;
      background:linear-gradient(135deg,#fff,#f7faff);
      box-shadow:0 8px 18px rgba(15,35,65,.05);
    }

    .line b{font-size:13px}
    .line small{
      display:block;
      margin-top:4px;
      color:var(--muted);
      font-weight:850;
    }

    .money{
      font-weight:950;
      color:var(--green);
    }

    .mutebox{
      padding:13px 14px;
      border:1px solid rgba(12,24,40,.08);
      border-radius:18px;
      background:linear-gradient(135deg,#fff,#f7faff);
      font-size:12.5px;
      line-height:1.55;
      color:var(--muted);
      font-weight:700;
      box-shadow:var(--shadow-soft);
    }

    .hr{
      height:1px;
      background:rgba(12,24,40,.10);
      margin:12px 0;
    }

    .form-grid,.doc-grid,.modal-grid,.modal-summary,.preview-grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:10px;
      margin-top:10px;
    }

    .modal-summary{
      grid-template-columns:repeat(3,1fr);
    }

    .field{
      display:flex;
      flex-direction:column;
      gap:6px;
    }

    label{
      font-size:12px;
      color:var(--muted);
      font-weight:950;
      letter-spacing:.02em;
    }

    input,select,textarea{
      width:100%;
      padding:12px 13px;
      border-radius:14px;
      border:1px solid rgba(12,24,40,.10);
      background:#fff;
      font:inherit;
      font-size:13px;
      outline:none;
      transition:border-color .12s ease, box-shadow .12s ease;
    }

    textarea{
      min-height:110px;
      resize:vertical;
    }

    input:focus,select:focus,textarea:focus{
      border-color:rgba(31,95,191,.55);
      box-shadow:0 0 0 4px rgba(31,95,191,.12);
    }

    .input-error{
      border-color:rgba(204,56,56,.7) !important;
      box-shadow:0 0 0 4px rgba(204,56,56,.12) !important;
    }

    .help-error{
      color:var(--red);
      font-size:12px;
      font-weight:900;
      display:none;
    }

    .cta{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      align-items:center;
      margin-top:12px;
    }

    .tickgrid{
      display:grid;
      grid-template-columns:1fr;
      gap:10px;
      margin-top:10px;
      padding:12px;
      border:1px solid rgba(12,24,40,.08);
      border-radius:16px;
      background:linear-gradient(135deg,#fff,#f7faff);
    }

    .tickrow{
      display:flex;
      align-items:center;
      gap:10px;
      font-size:12px;
      color:var(--muted);
      font-weight:900;
    }

    .tickrow input{
      width:18px;
      height:18px;
      min-height:auto;
      padding:0;
      flex:0 0 auto;
    }

    .protect-card,.gate-box,.room-entry,.meta-box,.preview-box{
      border:1px solid rgba(12,24,40,.08);
      border-radius:18px;
      background:linear-gradient(135deg,#fff,#f7faff);
      box-shadow:var(--shadow-soft);
      padding:14px;
    }

    .gate-error{
      display:none;
      color:var(--red);
      font-size:12px;
      font-weight:900;
      margin-top:8px;
    }

    .area-cta{
      margin-top:6px;
      padding:16px;
      border-radius:18px;
      background:linear-gradient(135deg,#f7fbff,#ffffff);
      border:2px solid rgba(31,95,191,.16);
      box-shadow:var(--shadow-soft);
    }

    .area-cta h3{margin:0 0 8px;font-size:20px;color:var(--brand3)}
    .area-cta p{margin:0;font-size:13px;line-height:1.6;color:var(--muted);font-weight:700}

    .room-list{display:flex;flex-direction:column;gap:12px;margin-top:14px}
    .room-row{
      border:1px solid rgba(31,95,191,.14);
      border-radius:18px;
      padding:14px;
      background:linear-gradient(135deg,#ffffff,#f8fbff);
      box-shadow:0 12px 24px rgba(15,35,65,.08), 0 0 0 1px rgba(255,255,255,.70) inset;
    }

    .room-top{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      margin-bottom:10px;
    }

    .room-badge{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:8px 12px;
      border-radius:999px;
      background:rgba(31,95,191,.08);
      color:var(--brand3);
      font-size:12px;
      font-weight:1000;
      text-transform:uppercase;
      letter-spacing:.06em;
    }

    footer{
      text-align:center;
      color:#5c6b80;
      font-size:12px;
      font-weight:700;
      margin-top:20px;
      padding-top:8px;
    }

    .sticky-bar{
      position:fixed;
      left:0;
      right:0;
      bottom:0;
      background:linear-gradient(135deg,#0e2a55,#091a32);
      color:#fff;
      border-top:1px solid rgba(255,255,255,.10);
      box-shadow:0 -14px 34px rgba(0,0,0,.28);
      padding:10px 12px calc(10px + env(safe-area-inset-bottom));
      z-index:9999;
      backdrop-filter:blur(12px);
    }

    .sticky-inner{
      max-width:var(--max);
      margin:0 auto;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      flex-wrap:nowrap;
    }

    .sticky-total{
      display:flex;
      flex-direction:column;
      font-weight:900;
      min-width:112px;
    }

    .sticky-total span{
      font-size:11px;
      opacity:.80;
      line-height:1.1;
      text-transform:uppercase;
      letter-spacing:.05em;
    }

    .sticky-total b{
      font-size:18px;
      letter-spacing:-.02em;
      line-height:1.1;
      margin-top:2px;
    }

    .sticky-actions{
      display:flex;
      gap:8px;
      flex-wrap:nowrap;
      align-items:center;
    }

    .modal{
      position:fixed;
      inset:0;
      z-index:10050;
      display:none;
      align-items:center;
      justify-content:center;
      padding:18px;
      background:rgba(6,16,30,.58);
      backdrop-filter:blur(8px);
    }

    .modal.show{display:flex}

    .modal-card{
      width:min(980px,96vw);
      max-height:94vh;
      overflow:auto;
      background:#fff;
      border-radius:24px;
      box-shadow:0 30px 80px rgba(0,0,0,.30);
      border:1px solid rgba(255,255,255,.55);
    }

    .modal-head{
      padding:20px 20px 16px;
      background:linear-gradient(135deg,#10305d 0%, #0d2548 56%, #09182d 100%);
      color:#fff;
      position:sticky;
      top:0;
      z-index:2;
    }

    .modal-head h3{margin:0;font-size:28px;line-height:1.05;letter-spacing:-.03em}
    .modal-head p{margin:8px 0 0;opacity:.92;font-size:14px;line-height:1.5}
    .modal-body{padding:18px}

    .preview-box h4{
      margin:0 0 8px;
      font-size:18px;
      line-height:1.1;
      color:var(--brand3);
    }

    .preview-box p{
      margin:0;
      font-size:13px;
      line-height:1.7;
      color:var(--muted);
      font-weight:700;
    }

    .meta-box span{
      display:block;
      font-size:12px;
      color:var(--muted);
      font-weight:900;
      text-transform:uppercase;
      letter-spacing:.05em;
    }

    .meta-box b{
      display:block;
      margin-top:6px;
      font-size:18px;
      color:var(--brand3);
      line-height:1.4;
    }

    @media (max-width: 980px){
      .grid,.form-grid,.summary,.doc-grid,.modal-grid,.modal-summary,.preview-grid{grid-template-columns:1fr}
      .hero-top{align-items:flex-start}
    }

    @media (max-width: 600px){
      body{padding-bottom:86px}
      .wrap{padding:12px 12px 20px}
      .topbar{padding:2px 0 10px}
      .top-actions{display:none}
      .brand-title,.brand span{display:none}
      .brand img{height:36px}
      .hero{padding:14px 12px;border-radius:18px}
      .hero-kicker,.hero-total{display:none}
      .hero h1{font-size:20px}
      .hero p{font-size:12.5px;line-height:1.45}
      .hero-showcase img{height:150px;object-position:center}
      .items{grid-template-columns:1fr;gap:10px}
      .item{padding:11px;border-radius:16px}
      .card-h{padding:13px 14px}
      .card-b{padding:14px}
      .sticky-bar{padding:8px 10px calc(8px + env(safe-area-inset-bottom))}
      .sticky-inner{gap:8px}
      .sticky-total{min-width:84px}
      .sticky-total span{font-size:10px}
      .sticky-total b{font-size:15px}
      .sticky-actions{gap:6px}
      .sticky-actions .btn{padding:9px 10px;font-size:12px;box-shadow:none}
      .modal-card{width:100%;border-radius:18px}
      .modal-head h3{font-size:22px}
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="topbar">
      <div class="brand">
        <img src="https://raw.githubusercontent.com/carpetcleaningcompany007-maker/Jw-Carpet-Care/main/Screenshot%202026-03-05%20221453.png" alt="JW Carpet Care">
        <div class="brand-copy">
          <div class="brand-title">JW Carpet Care</div>
          <span>Professional carpet and upholstery cleaning across Worcestershire</span>
        </div>
      </div>
      <div class="top-actions">
        <a class="btn primary" href="#callback">Request a quote</a>
        <a class="btn ghost" href="tel:07838231389">Call 07838 231389</a>
      </div>
    </div>

    <section class="hero">
      <div class="hero-top">
        <div class="hero-copy">
          <div class="hero-kicker">Instant estimate</div>
          <h1>Welcome to the JW Carpet Care calculator</h1>
          <p>Add domestic rooms and items as normal, or open the commercial section to build area based pricing for larger work.</p>
        </div>
        <div class="hero-total">
          <div>
            <b id="heroTotal">£0.00</b>
            <span>Live total</span>
          </div>
        </div>
      </div>

      <div class="hero-showcase">
        <img src="https://raw.githubusercontent.com/carpetcleaningcompany007-maker/Jw-Carpet-Care/main/ChatGPT%20Image%20Feb%2025,%202026,%2012_47_23%20PM.png" alt="JW Carpet Care cleaning results">
      </div>
    </section>

    <div class="grid">
      <section class="card">
        <div class="card-h">
          <h2>Build your quote</h2>
          <small>Select domestic items or add commercial areas</small>
        </div>
        <div class="card-b">
          <div class="summary">
            <div class="total-box">
              <span>Total estimate</span>
              <b id="total">£0.00</b>
            </div>
