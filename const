      event.preventDefault();
      alert("Quote request captured on the page. Add your form endpoint or email handler to make this send automatically.");
      return false;
    }

    document.getElementById("unlockDocsBtn").addEventListener("click", unlockDocTools);
    document.getElementById("docPassword").addEventListener("keydown", e => {
      if (e.key === "Enter") unlockDocTools();
    });

    document.getElementById("previewQuoteBtn").addEventListener("click", openQuotePreview);
    document.getElementById("pdfQuoteBtn").addEventListener("click", openPdfQuote);
    document.getElementById("excelQuoteBtn").addEventListener("click", downloadExcelQuote);
    document.getElementById("pdfInvoiceBtn").addEventListener("click", openPdfInvoice);
