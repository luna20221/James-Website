        alert("Please add at least one item before opening the PDF quote.");
        return;
      }
      const win = window.open("", "_blank");
      if (!win){
        alert("Popup blocked. Please allow popups for this page.");
        return;
      }
      win.document.open();
      win.document.write(buildDocumentHtml("quote"));
      win.document.close();
    }

    function openPdfInvoice(){
