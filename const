    document.getElementById("previewOpenPdfBtn").addEventListener("click", openPdfQuote);
    document.getElementById("previewOpenExcelBtn").addEventListener("click", downloadExcelQuote);
    document.getElementById("closePreviewBtn").addEventListener("click", closeQuotePreview);
    document.getElementById("quotePreviewModal").addEventListener("click", e => {
      if (e.target.id === "quotePreviewModal") closeQuotePreview();
    });

    document.getElementById("addRoomTop").addEventListener("click", openModalForNew);
    document.getElementById("resetCommercialBtn").addEventListener("click", resetCommercialOnly);
    document.getElementById("saveModalBtn").addEventListener("click", saveModal);
