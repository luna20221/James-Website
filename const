    const fmt = n => "£" + (Math.round((Number(n)||0) * 100) / 100).toFixed(2);

    function escapeHtml(str){
      return String(str ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    function nl2br(str){
      return escapeHtml(str).replace(/\n/g, "<br>");
    }

    const allDomesticItems = () => [
      ...ITEMS.carpets.map(x => ({...x, group:"Carpets"})),
      ...ITEMS.rugs.map(x => ({...x, group:"Rugs"})),
      ...ITEMS.upholstery.map(x => ({...x, group:"Sofas and Upholstery"}))
    ];

    function renderGroup(el, items){
      el.innerHTML = items.map(it => {
        const q = state.qty[it.id] || 0;
        return `
          <article class="item" data-id="${it.id}">
            <div style="min-width:0">
              <h3>${it.name}</h3>
              <p>${it.desc}</p>
              <div class="price">${fmt(it.price)}</div>
            </div>
            <div class="qty">
              <button class="qbtn" type="button" data-act="dec">−</button>
              <div class="qnum">${q}</div>
              <button class="qbtn" type="button" data-act="inc">+</button>
            </div>
          </article>
        `;
      }).join("");
    }

    function attachQtyHandlers(container){
      container.addEventListener("click", (e) => {
        const btn = e.target.closest(".qbtn");
        if (!btn) return;
        const card = btn.closest(".item");
        if (!card) return;
        const id = card.getAttribute("data-id");
        const act = btn.getAttribute("data-act");
        const cur = Number(state.qty[id] || 0);
        state.qty[id] = act === "inc" ? cur + 1 : Math.max(0, cur - 1);
        renderSelected();
      });
    }

    function getBands(method){
      if (method === "rotary") return ROTARY_BANDS;
      if (method === "hybrid") return HYBRID_BANDS;
      if (method === "hardfloor") return HARD_FLOOR_BANDS;
      return HWE_BANDS;
    }

    function getMethodLabel(method){
      if (method === "rotary") return "Rotary bonnet";
      if (method === "hybrid") return "Hybrid Deep Clean";
      if (method === "hardfloor") return "Hard floor cleaning";
      return "Hot water extraction";
    }

    function pickBand(m2, bands){
      if (m2 <= 0) return null;
      return bands.find(b => m2 >= b.min && m2 <= b.max) || bands[bands.length - 1];
    }

    function buildAreaOptions(selected){
      let html = `<option value="">Select area</option>`;
      AREA_OPTIONS.forEach(option => {
        html += `<option value="${escapeHtml(option)}" ${selected === option ? "selected" : ""}>${escapeHtml(option)}</option>`;
      });
      return html;
    }

    function getDisplayAreaName(row){
      return row.areaType && row.areaType !== "Custom" ? row.areaType : (row.roomName || "Unnamed area");
    }

    function createRoomRowElement(row, index){
      const sqm = Math.max(0, Number(row.sqm) || 0);
      const band = pickBand(sqm, getBands(row.method));
      const total = band ? sqm * band.rate : 0;
      const bandLabel = band ? band.label : "Waiting for details";

      const wrapper = document.createElement("div");
      wrapper.className = "room-row";
      wrapper.dataset.id = row.id;
      wrapper.innerHTML = `
        <div class="room-top">
          <div class="room-badge">Area ${index + 1}</div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;">
            <button class="btn primary small" type="button" data-role="edit" data-id="${row.id}">Edit</button>
            <button class="btn red small" type="button" data-role="remove" data-id="${row.id}">Remove</button>
          </div>
        </div>
        <div class="list">
          <div class="line">
            <div>
              <b>${escapeHtml(getDisplayAreaName(row))}</b>
              <small>${escapeHtml(getMethodLabel(row.method))} · ${sqm} m² · ${bandLabel}</small>
            </div>
            <div class="money">${fmt(total)}</div>
          </div>
        </div>
      `;
      return wrapper;
    }

    function renderRoomRows(){
      const wrap = document.getElementById("roomList");
      document.getElementById("commercialAreaCount").textContent = roomRows.length;
      if (!roomRows.length){
        wrap.innerHTML = `<div class="mutebox">No commercial areas added yet. Click Add area to start building the commercial quote.</div>`;
        return;
      }
      wrap.innerHTML = "";
      roomRows.forEach((row, index) => wrap.appendChild(createRoomRowElement(row, index)));
    }

    function addRoomRow(data = {}){
      roomCounter += 1;
      roomRows.push({
        id: roomCounter,
        areaType: data.areaType || "",
        roomName: data.roomName || "",
        method: data.method || "",
        sqm: Number(data.sqm || 0)
      });
      renderRoomRows();
      renderSelected();
    }

    function removeRoomRow(id){
      roomRows = roomRows.filter(r => r.id !== id);
      renderRoomRows();
      renderSelected();
    }

    function resetCommercialOnly(){
      roomRows = [];
      roomCounter = 0;
      editingRoomId = null;
      document.getElementById("hotelRoomMethod").value = "rotary";
      document.getElementById("hotelRoomQty").value = 0;
      document.getElementById("furnitureMoveDesc").value = "";
      document.getElementById("furnitureMovePrice").value = 0;
      document.getElementById("extrasDesc").value = "";
      document.getElementById("extrasPrice").value = 0;
      renderRoomRows();
      renderSelected();
    }

    function clearModalErrors(){
      ["modalAreaType","modalRoomName","modalMethod","modalSqm"].forEach(id => {
        document.getElementById(id).classList.remove("input-error");
      });
      ["areaTypeError","roomNameError","methodError","sqmError"].forEach(id => {
        document.getElementById(id).style.display = "none";
      });
    }

    function populateModalAreaOptions(selected){
      document.getElementById("modalAreaType").innerHTML = buildAreaOptions(selected || "");
    }

    function updateCustomNameRequirement(){
      const areaType = document.getElementById("modalAreaType").value;
      const roomNameInput = document.getElementById("modalRoomName");
      roomNameInput.disabled = areaType !== "Custom";
      if (areaType !== "Custom") roomNameInput.value = "";
    }

    function updateModalPreview(){
      const areaType = document.getElementById("modalAreaType").value;
      const method = document.getElementById("modalMethod").value;
      const sqm = Math.max(0, Number(document.getElementById("modalSqm").value) || 0);

      updateCustomNameRequirement();

      if (!areaType || !method || sqm <= 0){
        document.getElementById("modalBand").textContent = "Waiting for details";
        document.getElementById("modalRate").textContent = "—";
        document.getElementById("modalLineTotal").textContent = "£0.00";
        return;
      }

      const band = pickBand(sqm, getBands(method));
      document.getElementById("modalBand").textContent = band ? band.label : "Waiting for details";
      document.getElementById("modalRate").textContent = band ? `${fmt(band.rate)} per m²` : "—";
      document.getElementById("modalLineTotal").textContent = band ? fmt(sqm * band.rate) : "£0.00";
    }

    function openModalForNew(){
      editingRoomId = null;
      document.getElementById("modalTitle").textContent = "Add area";
      populateModalAreaOptions("");
      document.getElementById("modalRoomName").value = "";
      document.getElementById("modalMethod").value = "";
      document.getElementById("modalSqm").value = "";
      clearModalErrors();
      updateModalPreview();
      document.getElementById("roomModal").classList.add("show");
    }

    function openModalForEdit(id){
      const row = roomRows.find(r => r.id === id);
      if (!row) return;
      editingRoomId = id;
      document.getElementById("modalTitle").textContent = "Edit area";
      populateModalAreaOptions(row.areaType || "");
      document.getElementById("modalRoomName").value = row.roomName || "";
      document.getElementById("modalMethod").value = row.method || "";
      document.getElementById("modalSqm").value = row.sqm || "";
      clearModalErrors();
      updateModalPreview();
      document.getElementById("roomModal").classList.add("show");
    }

    function closeModal(){
      document.getElementById("roomModal").classList.remove("show");
      editingRoomId = null;
      clearModalErrors();
    }

    function validateModal(){
      clearModalErrors();
      const areaType = document.getElementById("modalAreaType").value.trim();
      const roomName = document.getElementById("modalRoomName").value.trim();
      const method = document.getElementById("modalMethod").value.trim();
      const sqm = Number(document.getElementById("modalSqm").value);
      let ok = true;

      if (!areaType){
        document.getElementById("modalAreaType").classList.add("input-error");
        document.getElementById("areaTypeError").style.display = "block";
        ok = false;
      }
      if (areaType === "Custom" && !roomName){
        document.getElementById("modalRoomName").classList.add("input-error");
        document.getElementById("roomNameError").style.display = "block";
        ok = false;
      }
      if (!method){
        document.getElementById("modalMethod").classList.add("input-error");
        document.getElementById("methodError").style.display = "block";
        ok = false;
      }
      if (!(sqm > 0)){
        document.getElementById("modalSqm").classList.add("input-error");
        document.getElementById("sqmError").style.display = "block";
        ok = false;
      }
      return ok;
    }

    function saveModal(){
      if (!validateModal()) return;

      const areaType = document.getElementById("modalAreaType").value;
      const roomName = document.getElementById("modalRoomName").value.trim();
      const method = document.getElementById("modalMethod").value;
      const sqm = Math.max(0, Number(document.getElementById("modalSqm").value) || 0);

      if (editingRoomId === null){
        addRoomRow({ areaType, roomName, method, sqm });
      } else {
        const row = roomRows.find(r => r.id === editingRoomId);
        if (row){
          row.areaType = areaType;
          row.roomName = roomName;
          row.method = method;
          row.sqm = sqm;
          renderRoomRows();
          renderSelected();
        }
      }
      closeModal();
    }

    function calculate(){
      let subtotal = 0;
      const lines = [];

      for (const it of allDomesticItems()) {
        const q = Number(state.qty[it.id] || 0);
        if (!q) continue;

        const rowTotal = q * it.price;
        subtotal += rowTotal;

        lines.push({
          roomName: it.name,
          method: it.group,
          methodKey: "domestic",
          sqm: "",
          band: it.group,
          rate: it.price,
          total: rowTotal,
          qtyRooms: q,
          group: it.group
        });
      }

      roomRows.forEach(row => {
        const sqm = Math.max(0, Number(row.sqm) || 0);
        if (!sqm || !row.method) return;
        const band = pickBand(sqm, getBands(row.method));
        if (!band) return;
        const total = sqm * band.rate;
        subtotal += total;
        lines.push({
          roomName: getDisplayAreaName(row),
          method: getMethodLabel(row.method),
          methodKey: row.method,
          sqm,
          band: band.label,
          rate: band.rate,
          total,
          group: "Commercial Work"
        });
      });

      const hotelRoomQty = Math.max(0, Number(document.getElementById("hotelRoomQty").value) || 0);
      const hotelRoomMethod = document.getElementById("hotelRoomMethod").value;
      if (hotelRoomQty > 0){
        let rate = ROTARY_ROOM_RATE;
        let method = "Rotary bonnet hotel room";
        let methodKey = "rotary";
        if (hotelRoomMethod === "hybrid"){ rate = HYBRID_ROOM_RATE; method = "Hybrid Deep Clean hotel room"; methodKey = "hybrid"; }
        if (hotelRoomMethod === "hwe"){ rate = HWE_ROOM_RATE; method = "Hot water extraction hotel room"; methodKey = "hwe"; }
        const total = hotelRoomQty * rate;
        subtotal += total;
        lines.push({
          roomName:"Hotel rooms",
          method,
          methodKey,
          sqm:"",
          band:"Room rate",
          rate,
          total,
          qtyRooms:hotelRoomQty,
          group:"Commercial Work"
        });
      }

      const furnitureMoveDesc = document.getElementById("furnitureMoveDesc").value.trim() || "Furniture moving";
      const furnitureMovePrice = Math.max(0, Number(document.getElementById("furnitureMovePrice").value) || 0);
      if (furnitureMovePrice > 0){
        subtotal += furnitureMovePrice;
        lines.push({
          roomName:furnitureMoveDesc,
          method:"Manual extra",
          methodKey:"extra",
          sqm:"",
          band:"Furniture moving",
          rate:furnitureMovePrice,
          total:furnitureMovePrice,
          isManualExtra:true,
          group:"Commercial Work"
        });
      }

      const extrasDesc = document.getElementById("extrasDesc").value.trim() || "Chemicals or other extras";
      const extrasPrice = Math.max(0, Number(document.getElementById("extrasPrice").value) || 0);
      if (extrasPrice > 0){
        subtotal += extrasPrice;
        lines.push({
          roomName:extrasDesc,
          method:"Manual extra",
          methodKey:"extra",
          sqm:"",
          band:"Chemicals / other",
          rate:extrasPrice,
          total:extrasPrice,
          isManualExtra:true,
          group:"Commercial Work"
        });
      }

      const includeVat = document.getElementById("includeVat").checked;
      const vat = includeVat ? subtotal * VAT_RATE : 0;
      const total = subtotal + vat;

      return { lines, subtotal, vat, total, includeVat };
    }

    function renderSelected(){
      renderGroup(document.getElementById("carpets"), ITEMS.carpets);
      renderGroup(document.getElementById("rugs"), ITEMS.rugs);
      renderGroup(document.getElementById("upholstery"), ITEMS.upholstery);

      document.getElementById("carpetCount").textContent = ITEMS.carpets.reduce((sum, it) => sum + (Number(state.qty[it.id]) || 0), 0);
      document.getElementById("rugCount").textContent = ITEMS.rugs.reduce((sum, it) => sum + (Number(state.qty[it.id]) || 0), 0);
      document.getElementById("upCount").textContent = ITEMS.upholstery.reduce((sum, it) => sum + (Number(state.qty[it.id]) || 0), 0);

      renderRoomRows();

      const result = calculate();
      document.getElementById("total").textContent = fmt(result.total);
      document.getElementById("totalSticky").textContent = fmt(result.total);
      document.getElementById("heroTotal").textContent = fmt(result.total);
      document.getElementById("totalHidden").value = fmt(result.total);

      const selected = document.getElementById("selectedList");

      if (!result.lines.length) {
        selected.innerHTML = `<div class="mutebox">No items selected yet. Add rooms, furniture or commercial areas to see the estimate.</div>`;
      } else {
        let html = result.lines.map(line => {
          const subText = line.isManualExtra
            ? `${line.method} · ${line.band}`
            : line.group === "Commercial Work" && line.qtyRooms
              ? `${line.method} · ${line.qtyRooms} × ${fmt(line.rate)} · ${line.band}`
              : line.group === "Commercial Work" && line.sqm
                ? `${line.method} · ${line.sqm} m² × ${fmt(line.rate)} · ${line.band}`
                : `${line.group} · ${line.qtyRooms} × ${fmt(line.rate)}`;

          return `
            <div class="line">
              <div>
                <b>${escapeHtml(line.roomName)}</b>
                <small>${escapeHtml(subText)}</small>
              </div>
              <div class="money">${fmt(line.total)}</div>
            </div>
          `;
        }).join("");

        html += `
          <div class="hr"></div>
          <div class="line">
            <div><b>Subtotal</b><small>Before VAT</small></div>
            <div class="money">${fmt(result.subtotal)}</div>
          </div>
        `;
        if (result.includeVat){
          html += `
            <div class="line">
              <div><b>VAT</b><small>20 percent added</small></div>
              <div class="money">${fmt(result.vat)}</div>
            </div>
          `;
        }
        html += `
          <div class="line" style="background:linear-gradient(135deg,#f3f7ff,#ffffff)">
            <div><b>Total</b><small>Instant estimate</small></div>
            <div class="money">${fmt(result.total)}</div>
          </div>`;
        selected.innerHTML = html;
      }

      const breakdown = [
        ...result.lines.map(x => `${x.roomName}: ${fmt(x.total)}`),
        `Final total: ${fmt(result.total)}`
      ].join("\n");

      document.getElementById("breakdown").value = breakdown;
    }

    function unlockDocTools(){
      const pw = document.getElementById("docPassword").value;
      const error = document.getElementById("docGateError");
      if (pw === DOC_PASSWORD){
        document.getElementById("docGate").classList.add("hidden");
        document.getElementById("docTools").classList.remove("hidden");
        error.style.display = "none";
      } else {
        error.style.display = "block";
      }
    }

    function getClientName(){
      return document.getElementById("clientNameDoc").value.trim() || document.getElementById("name").value.trim() || "Client";
    }

    function getBool(id){
      const el = document.getElementById(id);
      return !!(el && el.checked);
    }

    function getDocData(){
      return {
        clientName: getClientName(),
        siteName: document.getElementById("siteNameDoc").value.trim() || "Property",
        address: document.getElementById("addressDoc").value.trim() || "",
        quoteRef: document.getElementById("quoteRef").value.trim() || "Not entered",
        invoiceRef: document.getElementById("invoiceRef").value.trim() || "Not entered",
        invoiceDueDate: document.getElementById("invoiceDueDate").value,
        description: document.getElementById("descriptionDoc").value.trim() || "Professional carpet and upholstery cleaning service.",
        quoteIntro: document.getElementById("quoteIntro").value.trim() || "This quote has been prepared based on the items selected in the calculator and is intended as a clear breakdown of the cleaning services requested.",
        quoteWorkText: document.getElementById("quoteWorkText").value.trim() || "All work will be carried out using professional carpet and upholstery cleaning equipment, together with solutions appropriate to the fibre type and level of soiling.",
        invoiceWorkText: document.getElementById("invoiceWorkText").value.trim() || "All work has been carried out using professional carpet and upholstery cleaning equipment, together with solutions appropriate to the fibre type and level of soiling.",
        commercialSectionText: document.getElementById("commercialSectionText").value.trim() || "This service has been priced to reflect the selected commercial areas and the practical requirements of the job.",
        notes: document.getElementById("quoteNotesDoc").value.trim() || "",
        includeFreeProtection: getBool("includeFreeProtection"),
        includeDescription: getBool("includeDescription"),
        includeQuoteIntro: getBool("includeQuoteIntro"),
        includeCommercialSection: getBool("includeCommercialSection"),
        includeWorkText: getBool("includeWorkText"),
        includeWhatsIncluded: getBool("includeWhatsIncluded"),
        includeNotesSection: getBool("includeNotesSection")
      };
    }

    function buildWhatsIncludedHtml(){
      const data = getDocData();
      const result = calculate();

      const hasDomesticCarpets = result.lines.some(x => x.group === "Carpets");
      const hasRugs = result.lines.some(x => x.group === "Rugs");
      const hasUpholstery = result.lines.some(x => x.group === "Sofas and Upholstery");
      const hasCommercial = result.lines.some(x => x.group === "Commercial Work");

      const usedMethods = new Set();
      const parts = [];

      if (hasDomesticCarpets){
        parts.push("Carpet cleaning has been included based on the selected rooms and areas.");
      }
      if (hasRugs){
        parts.push("Rug cleaning has been included for the selected rug items.");
      }
      if (hasUpholstery){
        parts.push("Upholstery cleaning has been included for the selected seating items.");
      }

      result.lines.forEach(line => {
        if (line.group !== "Commercial Work" || line.isManualExtra) return;
        if (usedMethods.has(line.methodKey)) return;
        usedMethods.add(line.methodKey);

        if (line.methodKey === "rotary"){
          parts.push("Rotary bonnet cleaning has been selected where appropriate for commercial carpeted areas to improve appearance and refresh the fibres." + (data.includeFreeProtection ? " Complimentary protection has been included at no additional charge." : ""));
        } else if (line.methodKey === "hybrid"){
          parts.push("A hybrid deep clean has been selected for commercial areas requiring a stronger level of cleaning." + (data.includeFreeProtection ? " Complimentary protection has been included at no additional charge." : ""));
        } else if (line.methodKey === "hwe"){
          parts.push("Hot water extraction has been selected for deeper restorative cleaning of commercial carpet areas." + (data.includeFreeProtection ? " Complimentary protection has been included at no additional charge." : ""));
        } else if (line.methodKey === "hardfloor"){
          parts.push("Hard floor cleaning has been included where appropriate to improve the appearance of non carpeted areas.");
        }
      });

      if (!parts.length && hasCommercial){
        parts.push("Commercial cleaning services have been included based on the selected areas.");
      }

      if (!parts.length){
        parts.push("Professional cleaning services have been selected based on the items included in this document.");
      }

      return parts.map(p => `<p style="margin:0 0 10px;">${escapeHtml(p)}</p>`).join("");
    }

    function buildPreviewHtml(){
      const result = calculate();
      const data = getDocData();
      const hasCommercial = result.lines.some(x => x.group === "Commercial Work");

      if (!result.lines.length){
        return `<div class="mutebox">Add at least one item before opening the quote preview.</div>`;
      }

      const lineHtml = result.lines.map(x => `
        <div class="line">
          <div>
            <b>${escapeHtml(x.roomName)}</b>
            <small>${escapeHtml(x.group)} · ${x.qtyRooms ? `${x.qtyRooms} × ${fmt(x.rate)}` : x.sqm ? `${x.sqm} m² × ${fmt(x.rate)}` : x.method}</small>
          </div>
          <div class="money">${fmt(x.total)}</div>
        </div>
      `).join("");

      return `
        ${data.includeQuoteIntro ? `
        <div class="preview-box">
          <h4>Quote overview</h4>
          <p>${escapeHtml(data.quoteIntro)}</p>
          <p style="margin-top:10px;">Prepared for ${escapeHtml(data.clientName)} for ${escapeHtml(data.siteName)}.</p>
        </div>` : ""}

        ${data.includeDescription ? `
        <div class="preview-box">
          <h4>Main description</h4>
          <p>${escapeHtml(data.description)}</p>
        </div>` : ""}

        <div class="preview-box">
          <h4>Included in this quote</h4>
          <div class="list" style="margin-top:10px;">${lineHtml}</div>
        </div>

        <div class="preview-box">
          <h4>Total quote</h4>
          <p>Subtotal: ${fmt(result.subtotal)}${result.includeVat ? `<br>VAT: ${fmt(result.vat)}` : ""}<br><strong style="color:#14945c;font-size:28px;line-height:1.5;">Total: ${fmt(result.total)}</strong></p>
        </div>

        ${data.includeCommercialSection && hasCommercial ? `
        <div class="preview-box">
          <h4>Commercial section</h4>
          <p>${escapeHtml(data.commercialSectionText)}</p>
        </div>` : ""}

        ${data.includeWorkText ? `
        <div class="preview-box">
          <h4>Work description</h4>
          <p>${escapeHtml(data.quoteWorkText)}</p>
